#!/bin/bash

# Get the current branch name
branch="$(git rev-parse --abbrev-ref HEAD)"

# Check if the commit is on the 'main' branch
if [ "$branch" = "main" ]; then
    echo "Running pre-commit hook on branch 'main'..."
    
    # Enter the Assignment 4 directory where test.py exists
    # Using relative path from the root of the repository
    cd Assignment_4 || exit 1
    
    # Run pytest. If it fails, pytest returns exit code 1
    python -m pytest test.py
    
    # Capture the exit code of pytest
    RESULT=$?
    
    # If the exit code is not 0 (meaning tests failed)
    if [ $RESULT -ne 0 ]; then
        echo ""
        echo "🚨 ERROR: Tests failed! Commit blocked."
        echo "Please fix the failing tests before committing to the main branch."
        exit 1
    fi
    
    echo "✅ Tests passed! Proceeding with commit..."
fi

# Exit 0 means successful execution (allow commit)
exit 0
